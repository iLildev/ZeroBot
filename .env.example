# Arcana — environment variables (copy to .env and edit)
# All values shown are examples. Treat .env as a secret; never commit it.

# ─────────── Database ───────────
# PostgreSQL connection string. The asyncpg driver is enforced automatically,
# and `sslmode=...` query params (which asyncpg rejects) are stripped.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/arcana

# ─────────── Wallet / billing ───────────
# Crystals granted on first wallet creation.
INITIAL_CRYSTALS=10

# ─────────── Port registry ───────────
# Inclusive range of TCP ports the orchestrator may hand out to bot processes.
PORT_RANGE_START=30000
PORT_RANGE_END=30100

# ─────────── Admin console ───────────
# Shared secret required by every /admin/* route on the admin console.
# The Manager Bot must use the same value.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Owner / developer user id. When set, this user is created (if missing) and
# flagged is_admin during bootstrap, and the Builder Bot exempts them from
# crystal billing. By convention use the "tg-{telegram_user_id}" form.
ADMIN_USER_ID=

# ─────────── Hibernation ───────────
# Idle bots are reaped after this many seconds of inactivity.
HIBERNATION_TIMEOUT=1800
# Sweep cycle for the hibernator watchdog.
HIBERNATION_SWEEP=30

# ─────────── Builder Bot (Telegram) ───────────
# Token from @BotFather for the Builder Agent's Telegram bot.
BUILDER_BOT_TOKEN=
# Cost model: how many Anthropic tokens equal one crystal.
BUILDER_TOKENS_PER_CRYSTAL=5000
# Reject new turns when the user's balance drops below this.
BUILDER_MIN_BALANCE=1
# Outbound message length cap (Telegram's hard limit is 4096).
BUILDER_MAX_REPLY_LEN=3800
# Where Builder Agent sessions are persisted on disk (one JSON per user).
BUILDER_SESSION_DIR=runtime_envs/builder_sessions

# ─────────── Builder Agent sandbox limits ───────────
# All values are enforced via setrlimit() on Linux. Set any to 0 to disable.
SANDBOX_CPU_SECONDS=30
SANDBOX_MEM_MB=512
SANDBOX_FILE_MB=50
SANDBOX_MAX_PROCS=64

# ─────────── Manager Bot (Telegram) ───────────
# Token from @BotFather for the Manager Bot.
MANAGER_BOT_TOKEN=
# Numeric Telegram chat id allowed to issue admin commands.
MANAGER_ADMIN_CHAT_ID=
# URLs the Manager Bot will call (defaults match the per-process port plan).
ADMIN_CONSOLE_URL=http://127.0.0.1:8002
USER_CONSOLE_URL=http://127.0.0.1:8000
# HTTP port the Manager Bot exposes for inbound platform events.
MANAGER_EVENT_PORT=8003

# ─────────── Event publisher ───────────
# Where the platform pushes fire-and-forget events. Usually the Manager Bot's
# /events endpoint. Leave empty to disable event delivery.
MANAGER_EVENT_URL=http://127.0.0.1:8003/events
# HMAC-SHA256 secret shared between the publisher and the Manager Bot's
# /events endpoint. When set, every request is signed with the
# `X-Arcana-Signature: sha256=<hex>` header and unsigned requests are
# rejected. Leave empty in dev to disable signing.
EVENT_SHARED_SECRET=

# ─────────── Identity (Phase 0) ───────────
# Generate fresh keys with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# Both MUST be set in production. If left empty in dev, deterministic
# dev keys are used (you'll see a warning) — never ship that to prod.
MASTER_ENCRYPTION_KEY=
PHONE_HMAC_KEY=
# How many bots a verified user may plant for free. Admins override per-user.
FREE_BOT_QUOTA=3
# When true (default), bot creation and Builder Agent require a phone
# verified via Telegram's request_contact button. Set false only for
# local testing — disabling this in prod opens the platform to spam.
REQUIRE_PHONE_VERIFICATION=true

# ─────────── Anthropic AI integration ───────────
# Provided automatically by Replit's AI Integrations setup; uncomment + fill
# manually if you're running outside Replit.
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
